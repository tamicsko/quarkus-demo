<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002" author="benno">
        <createTable tableName="balance_history" schemaName="account_svc">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="account_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="old_balance" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="new_balance" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="change_amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableSchemaName="account_svc"
                baseTableName="balance_history"
                baseColumnNames="account_id"
                constraintName="fk_balance_history_account"
                referencedTableSchemaName="account_svc"
                referencedTableName="account"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
