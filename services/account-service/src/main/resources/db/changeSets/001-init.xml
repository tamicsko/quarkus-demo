<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-account" author="bank-demo">
        <createTable tableName="account" schemaName="account_svc">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="account_number" type="VARCHAR(34)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="customer_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="account_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="account" indexName="idx_account_customer_id" schemaName="account_svc">
            <column name="customer_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="001-create-balance-history" author="bank-demo">
        <createTable tableName="balance_history" schemaName="account_svc">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="account_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="old_balance" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="new_balance" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="change_amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="balance_history" baseColumnNames="account_id"
                                 baseTableSchemaName="account_svc"
                                 referencedTableName="account" referencedColumnNames="id"
                                 referencedTableSchemaName="account_svc"
                                 constraintName="fk_balance_history_account"/>
    </changeSet>

</databaseChangeLog>
